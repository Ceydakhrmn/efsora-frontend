POSTGRES_DB=envanter_db
POSTGRES_USER=efsora_user
POSTGRES_PASSWORD=change_this_password

# Minimum 32 chars for HS256/HS512 safety.
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=2592000000

# Frontend URL(s) allowed by backend CORS (comma-separated)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public backend URL used by Swagger server list
APP_BACKEND_PUBLIC_URL=http://localhost:8081

# Frontend -> backend API base URL (use in frontend/.env)
VITE_API_BASE_URL=http://localhost:8081
